# =====================================================================
# TOPPERS/ATK2 (NUCLEO-H563ZI 移植版) .gitignore
# =====================================================================

# ---------------------------------------------------------------------
# C / アセンブラ ビルド成果物
# ---------------------------------------------------------------------
*.o
*.obj
*.lo
*.la
*.a
*.so
*.so.*
*.dylib
*.exe
*.elf
*.out
*.hex
*.bin
*.srec
*.dump
*.map
*.syms
*.lst
*.lss

# 依存関係ファイル (gcc -MD / -MMD で生成)
*.d
Makefile.depend

# 中間オブジェクト・依存ファイル置き場 (Makefile で OBJDIR=objs)
**/objs/

# ---------------------------------------------------------------------
# ATK2 cfg ツール (C++ 版 / Python 版 共通) の生成物
# ---------------------------------------------------------------------
cfg1_out
cfg1_out.c
cfg1_out.db
cfg1_out.srec
cfg1_out.syms
cfg1_out.dump
cfg1_out.timestamp
cfg2_out.db
cfg2_out.tf
cfg3_out.db
Os_Lcfg.c
Os_Lcfg.h
Os_Lcfg.o
Os_Lcfg.timestamp
Os_Cfg.h
Os_Cfg_tmp.h
offset.h
offset.timestamp
kernel.res
check.timestamp

# ロードモジュール (アプリ名)
atk2-sc1
atk2-sc1.*

# カーネルライブラリ (cfg と並走で再生成される)
libkernel.a

# makerelease.py の出力先
/RELEASE/
RELEASE/*.tar.gz

# ---------------------------------------------------------------------
# Python ツール (cfg_py, utils, abrex)
# ---------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ---------------------------------------------------------------------
# STM32CubeIDE / Eclipse CDT
# ---------------------------------------------------------------------
# ワークスペース固有メタデータ (リポジトリに含めない)
.metadata/
RemoteSystemsTempFiles/

# CDT のローカル設定・履歴
.cdt-core-tasks
.recommenders/
local.properties

# IDE が生成するビルド出力ディレクトリ
Debug/
Release/

# launch / settings はユーザ環境依存だが，プロジェクト共有用は残せるよう
# 全消ししない (必要に応じて運用で除外)．以下は個人作業用のみを除外する想定．
# .launch  # ← コミットしたい場合があるので除外しない

# .settings/ はビルドや IDE 操作のたびに env-hash 等が変わるため除外
.settings/

# ---------------------------------------------------------------------
# エディタ / OS
# ---------------------------------------------------------------------
# Emacs / make
*~
\#*\#
.\#*

# Vim
*.swp
*.swo
*.swn

# VS Code (個人設定はコミットしない)
.vscode/

# JetBrains
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------
# ビルドログ・テンポラリ
# ---------------------------------------------------------------------
*.log
build_log.txt
*.bak
*.tmp
*.orig
*.rej

# ---------------------------------------------------------------------
# applyrename.py のバックアップファイル
# ---------------------------------------------------------------------
*_rename.h.bak
*_unrename.h.bak

# ---------------------------------------------------------------------
# OpenOCD / GDB
# ---------------------------------------------------------------------
*.gdb_history
.gdbinit
gdb_command.txt
