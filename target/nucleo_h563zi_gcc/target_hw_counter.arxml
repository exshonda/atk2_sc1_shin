<?xml version="1.0" encoding="UTF-8"?>
<!-- TOPPERS ATK2 NUCLEO-H563ZI Hardware Counter Configuration -->
<!-- MAIN_HW_COUNTER: TIM2 (free-running) + TIM5 (alarm, INTNO=64) -->
<!-- Timer clock: 1MHz (SYSCLK=250MHz / PSC=250) -->
<AUTOSAR xmlns="http://autosar.org/schema/r4.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-0-3_STRICT.xsd">
	<AR-PACKAGES>
		<AR-PACKAGE>
			<SHORT-NAME>Ecuc</SHORT-NAME>
			<ELEMENTS>
				<ECUC-MODULE-CONFIGURATION-VALUES>
					<SHORT-NAME>Os</SHORT-NAME>
					<DEFINITION-REF DEST="ECUC-MODULE-DEF">/AUTOSAR/EcucDefs/Os</DEFINITION-REF>
					<ECUC-DEF-EDITION>4.2.0</ECUC-DEF-EDITION>
					<IMPLEMENTATION-CONFIG-VARIANT>VARIANT-PRE-COMPILE</IMPLEMENTATION-CONFIG-VARIANT>
					<CONTAINERS>
						<ECUC-CONTAINER-VALUE>
							<SHORT-NAME>OsInclude</SHORT-NAME>
							<DEFINITION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Os/OsInclude</DEFINITION-REF>
							<PARAMETER-VALUES>
								<ECUC-TEXTUAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-STRING-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsInclude/OsIncludeFileName</DEFINITION-REF>
									<VALUE>target_hw_counter.h</VALUE>
								</ECUC-TEXTUAL-PARAM-VALUE>
							</PARAMETER-VALUES>
						</ECUC-CONTAINER-VALUE>
						<ECUC-CONTAINER-VALUE>
							<SHORT-NAME>MAIN_HW_COUNTER</SHORT-NAME>
							<DEFINITION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Os/OsCounter</DEFINITION-REF>
							<PARAMETER-VALUES>
								<!-- MaxAllowedValue = MAX_CNT_CYCLE = 0x7FFFFFFF -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsCounterMaxAllowedValue</DEFINITION-REF>
									<VALUE>2147483647</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<!-- MinCycle = 1000 ticks = 1ms -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsCounterMinCycle</DEFINITION-REF>
									<VALUE>1000</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<!-- TicksPerBase = 1000 (1000 ticks = 1ms base) -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsCounterTicksPerBase</DEFINITION-REF>
									<VALUE>1000</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<!-- SecondsPerTick = 1us = 1.0e-6 s -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-FLOAT-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsSecondsPerTick</DEFINITION-REF>
									<VALUE>1.0e-06</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<ECUC-TEXTUAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsCounterType</DEFINITION-REF>
									<VALUE>HARDWARE</VALUE>
								</ECUC-TEXTUAL-PARAM-VALUE>
							</PARAMETER-VALUES>
							<REFERENCE-VALUES>
								<ECUC-REFERENCE-VALUE>
									<DEFINITION-REF DEST="ECUC-REFERENCE-DEF">/AUTOSAR/EcucDefs/Os/OsCounter/OsCounterIsrRef</DEFINITION-REF>
									<VALUE-REF DEST="ECUC-CONTAINER-VALUE">/Ecuc/Os/C2ISR_for_MAIN_HW_COUNTER</VALUE-REF>
								</ECUC-REFERENCE-VALUE>
							</REFERENCE-VALUES>
						</ECUC-CONTAINER-VALUE>
						<ECUC-CONTAINER-VALUE>
							<SHORT-NAME>C2ISR_for_MAIN_HW_COUNTER</SHORT-NAME>
							<DEFINITION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/AUTOSAR/EcucDefs/Os/OsIsr</DEFINITION-REF>
							<PARAMETER-VALUES>
								<!-- TIM5_IRQn=48, INTNO=48+16=64 -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsIsr/OsIsrInterruptNumber</DEFINITION-REF>
									<VALUE>64</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<!-- 割込み優先度 1 (C2ISR, BASEPRI でマスク可) -->
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsIsr/OsIsrInterruptPriority</DEFINITION-REF>
									<VALUE>1</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<ECUC-NUMERICAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-INTEGER-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsIsr/OsIsrStackSize</DEFINITION-REF>
									<VALUE>592</VALUE>
								</ECUC-NUMERICAL-PARAM-VALUE>
								<ECUC-TEXTUAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsIsr/OsIsrCategory</DEFINITION-REF>
									<VALUE>CATEGORY_2</VALUE>
								</ECUC-TEXTUAL-PARAM-VALUE>
								<ECUC-TEXTUAL-PARAM-VALUE>
									<DEFINITION-REF DEST="ECUC-ENUMERATION-PARAM-DEF">/AUTOSAR/EcucDefs/Os/OsIsr/OsIsrInterruptSource</DEFINITION-REF>
									<VALUE>ENABLE</VALUE>
								</ECUC-TEXTUAL-PARAM-VALUE>
							</PARAMETER-VALUES>
						</ECUC-CONTAINER-VALUE>
					</CONTAINERS>
				</ECUC-MODULE-CONFIGURATION-VALUES>
			</ELEMENTS>
		</AR-PACKAGE>
	</AR-PACKAGES>
</AUTOSAR>
